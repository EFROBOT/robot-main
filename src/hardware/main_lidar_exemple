from lidar_module import LidarDetector
 
lidar = LidarDetector(port='/dev/ttyACM1')
 
try:
    while True:
        # Appel avec la distance souhaitée en cm
        obstacles = lidar.scan(distance_cm=20)
 
        print(f"ALERTE ! {len(obstacles)} points détectés")
        for obs in obstacles:
            print(f"  → {obs['distance_cm']}cm à {obs['angle']}°")
        print("---")
 
except KeyboardInterrupt:
    print("\nArrêt demandé.")
finally:
    lidar.stop()
